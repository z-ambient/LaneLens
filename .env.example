# Riot Games API key (required) - get one at https://developer.riotgames.com
# Backend-only. Never exposed to the browser.
RIOT_API_KEY=your_api_key_here

# OpenAI API key (optional) - enables AI-generated matchup advice.
# Without it, LaneLens uses its built-in deterministic advice engine.
OPENAI_API_KEY=

# AI model split (optional). PRIMARY = cacheable matchup sections (build,
# lane), generated once per matchup per patch and shared by all users.
# FAST = per-game sections (game plan, extras) regenerated every analysis.
# AI_MODEL_PRIMARY=gpt-5.5
# AI_MODEL_FAST=gpt-5.4-mini

# Default Riot routing values (optional)
DEFAULT_PLATFORM=na1
DEFAULT_REGION=americas

# Database (optional). Unset = local SQLite file at data/lanelens.db.
# In production (Railway etc.) set this to the Postgres connection string.
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Discord OAuth (optional) - enables "Sign in with Discord" accounts.
# Create an app at https://discord.com/developers/applications, then under
# OAuth2 copy the Client ID/Secret and register these redirect URLs:
#   http://127.0.0.1:8000/auth/callback   (local dev)
#   https://<your-domain>/auth/callback   (production)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
