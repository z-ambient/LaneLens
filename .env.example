# Riot Games API key (required) - get one at https://developer.riotgames.com
# Backend-only. Never exposed to the browser.
RIOT_API_KEY=your_api_key_here

# OpenAI API key (optional) - enables AI-generated matchup advice.
# Without it, LaneLens uses its built-in deterministic advice engine.
OPENAI_API_KEY=

# Default Riot routing values (optional)
DEFAULT_PLATFORM=na1
DEFAULT_REGION=americas
